[Unit]
Description=Autostart desktop applications for Arch Hyprland
PartOf=arch-hyprland-session.target
After=arch-hyprland-session.target graphical-session.target
After=kanshi.service quickshell.service swaybg-daemon.service

[Service]
Type=oneshot
ExecStart=%h/.local/bin/arch-autostart-apps
RemainAfterExit=yes
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=arch-hyprland-session.target
