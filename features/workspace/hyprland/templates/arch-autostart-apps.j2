#!/usr/bin/env bash
set -euo pipefail

log() {
  printf '[arch-autostart-apps] %s\n' "$*" >&2
}

wait_hyprland() {
  for _ in $(seq 1 100); do
    if hyprctl monitors >/dev/null 2>&1; then
      return 0
    fi

    sleep 0.1
  done

  log "Hyprland is not ready"
  return 1
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

process_exists() {
  local name="$1"
  pgrep -x "$name" >/dev/null 2>&1
}

dispatch_exec() {
  local workspace="$1"
  local command="$2"

  log "workspace ${workspace}: ${command}"
  hyprctl dispatch exec "[workspace ${workspace} silent] ${command}" >/dev/null 2>&1 || true
}

run_once() {
  local process_name="$1"
  local workspace="$2"
  local command="$3"

  if process_exists "$process_name"; then
    log "skip ${process_name}: already running"
    return 0
  fi

  dispatch_exec "$workspace" "$command"
}

run_first_available_once() {
  local process_name="$1"
  local workspace="$2"
  shift 2

  if process_exists "$process_name"; then
    log "skip ${process_name}: already running"
    return 0
  fi

  for candidate in "$@"; do
    local binary="${candidate%% *}"

    if command_exists "$binary"; then
      dispatch_exec "$workspace" "$candidate"
      return 0
    fi
  done

  log "skip ${process_name}: no command found"
}

wait_hyprland

# Даём kanshi/quickshell/swaybg немного времени.
sleep 1

# Старые DPI/GTK-настройки из Nix-конфига.
echo 'Xft.dpi: 125' | xrdb -merge >/dev/null 2>&1 || true
gsettings set org.gnome.desktop.interface text-scaling-factor 1.25 >/dev/null 2>&1 || true

# Обычный автозапуск.
# Здесь workspace задаётся через Hyprland exec rule, поэтому окна попадают туда
# даже если windowrule сработает позже или класс окна появится не сразу.

run_first_available_once "zen-browser" "1" \
  "zen-browser" \
  "zen" \
  "firefox"

sleep 0.4

run_once "steam" "5" "steam"

sleep 0.4

run_first_available_once "telegram-desktop" "10" \
  "telegram-desktop" \
  "Telegram"

sleep 0.4

run_once "spotify" "9" "spotify"

log "done"
