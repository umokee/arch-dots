#!/usr/bin/env bash
set -euo pipefail

export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"
export XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP:-Hyprland}"
export XDG_SESSION_DESKTOP="${XDG_SESSION_DESKTOP:-Hyprland}"

load_environment_d() {
  local file line key value

  for file in "$HOME/.config/environment.d/"*.conf; do
    [[ -f "$file" ]] || continue

    while IFS= read -r line || [[ -n "$line" ]]; do
      line="${line#"${line%%[![:space:]]*}"}"
      line="${line%"${line##*[![:space:]]}"}"

      [[ -z "$line" ]] && continue
      [[ "$line" == \#* ]] && continue
      [[ "$line" == *=* ]] || continue

      key="${line%%=*}"
      value="${line#*=}"

      [[ "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || continue

      export "$key=$value"
    done < "$file"
  done
}

load_environment_d

hyprland_pid=""
cleanup_done=0

log() {
  printf '[arch-hyprland-session] %s\n' "$*" >&2
}

cleanup() {
  if [[ "$cleanup_done" -eq 1 ]]; then
    return
  fi

  cleanup_done=1
  /usr/local/bin/arch-session-stop || true
}

terminate_hyprland() {
  if [[ -n "$hyprland_pid" ]]; then
    kill -TERM "$hyprland_pid" 2>/dev/null || true
  fi
}

trap terminate_hyprland INT TERM
trap cleanup EXIT

if command -v start-hyprland >/dev/null 2>&1; then
  log "starting Hyprland through start-hyprland"
  start-hyprland &
else
  log "starting Hyprland directly"
  Hyprland &
fi

hyprland_pid="$!"

log "starting arch user session services"
/usr/local/bin/arch-session-start || true

set +e
wait "$hyprland_pid"
status="$?"
set -e

exit "$status"
