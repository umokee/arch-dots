# Managed by archctl
# pam_faillock settings.

# Было по умолчанию слишком жёстко: блокировка после 3 ошибок.
# Теперь после 3 неверных sudo-паролей блокировки не будет.
deny = 10

# Окно подсчёта ошибок: 5 минут.
fail_interval = 300

# Если всё-таки набрал 10 ошибок подряд — разблокировать через 1 минуту.
unlock_time = 60

# Учитывать только локальных пользователей из /etc/passwd.
local_users_only
