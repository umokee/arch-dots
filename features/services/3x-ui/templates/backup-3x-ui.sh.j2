#!/usr/bin/env bash
set -euo pipefail

backup_dir="/opt/3x-ui/backups"
stamp="$(date +%Y-%m-%d_%H-%M-%S)"
archive="$backup_dir/3x-ui-native-$stamp.tar.gz"

mkdir -p "$backup_dir"

items=()

[[ -d /etc/x-ui ]] && items+=("etc/x-ui")
[[ -d /root/cert ]] && items+=("root/cert")
[[ -f /etc/archctl/3x-ui.generated.env ]] && items+=("etc/archctl/3x-ui.generated.env")
[[ -f /root/3x-ui-access.txt ]] && items+=("root/3x-ui-access.txt")

if [[ "${#items[@]}" -eq 0 ]]; then
  echo "Nothing to backup."
  exit 0
fi

tar -czf "$archive" -C / "${items[@]}"

find "$backup_dir" -type f -name '3x-ui-native-*.tar.gz' -mtime +14 -delete

echo "Backup created: $archive"
